# The app is local-first and needs no environment variables to run.
#
# These are only used by the one-time migration script
# (scripts/migrate-from-supabase.mjs) to pull an existing board out of an old
# Supabase deployment into a local soundboard-config.json. Delete after migrating.
SUPABASE_URL=https://your-project.supabase.co
# Service role key (Project → Settings → API). Bypasses RLS for the one-time
# local pull. Keep it secret; never ship it to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
